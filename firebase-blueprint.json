{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User specific settings and profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "currency": { "type": "string" },
        "theme": { "type": "string", "enum": ["light", "dark"] },
        "hasCompletedOnboarding": { "type": "boolean" }
      },
      "required": ["uid"]
    },
    "Expense": {
      "title": "Expense",
      "description": "A single expense transaction",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "categoryId": { "type": "string" },
        "subcategoryId": { "type": "string" },
        "accountId": { "type": "string" },
        "goalId": { "type": "string" },
        "date": { "type": "string" },
        "note": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "createdAt": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["amount", "categoryId", "date", "uid"]
    },
    "Income": {
      "title": "Income",
      "description": "A single income transaction",
      "type": "object",
      "properties": {
        "source": { "type": "string" },
        "amount": { "type": "number" },
        "accountId": { "type": "string" },
        "date": { "type": "string" },
        "createdAt": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["source", "amount", "date", "uid"]
    },
    "Category": {
      "title": "Category",
      "description": "Expense or income category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "color": { "type": "string" },
        "icon": { "type": "string" },
        "subcategories": { "type": "array", "items": { "type": "string" } },
        "type": { "type": "string", "enum": ["need", "want", "saving"] },
        "uid": { "type": "string" }
      },
      "required": ["name", "color", "uid"]
    },
    "Account": {
      "title": "Account",
      "description": "Financial account (bank, cash, etc.)",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "balance": { "type": "number" },
        "color": { "type": "string" },
        "icon": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["name", "balance", "uid"]
    },
    "Goal": {
      "title": "Goal",
      "description": "Savings goal",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "targetAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "deadline": { "type": "string" },
        "createdAt": { "type": "string" },
        "linkedCategoryId": { "type": "string" },
        "isLinkedToOverallBudget": { "type": "boolean" },
        "uid": { "type": "string" }
      },
      "required": ["name", "targetAmount", "uid"]
    },
    "RecurringExpense": {
      "title": "Recurring Expense",
      "description": "A subscription or recurring payment",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "categoryId": { "type": "string" },
        "subcategoryId": { "type": "string" },
        "accountId": { "type": "string" },
        "note": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "interval": { "type": "string" },
        "startDate": { "type": "string" },
        "nextDate": { "type": "string" },
        "createdAt": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["amount", "categoryId", "interval", "startDate", "nextDate", "uid"]
    },
    "Budget": {
      "title": "Budget",
      "description": "Monthly budget settings",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "month": { "type": "string" },
        "categoryBudgets": { "type": "object" },
        "uid": { "type": "string" }
      },
      "required": ["amount", "month", "uid"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/users/{userId}/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "User expenses"
    },
    "/users/{userId}/income/{incomeId}": {
      "schema": "Income",
      "description": "User income"
    },
    "/users/{userId}/categories/{categoryId}": {
      "schema": "Category",
      "description": "User custom categories"
    },
    "/users/{userId}/accounts/{accountId}": {
      "schema": "Account",
      "description": "User accounts"
    },
    "/users/{userId}/goals/{goalId}": {
      "schema": "Goal",
      "description": "User savings goals"
    },
    "/users/{userId}/recurringExpenses/{recurringId}": {
      "schema": "RecurringExpense",
      "description": "User recurring expenses"
    },
    "/users/{userId}/budgets/{budgetId}": {
      "schema": "Budget",
      "description": "User monthly budgets"
    }
  }
}
